---
import postsData from '../data.json';
import i18nData from '../i18n.json';

const posts = postsData || [];
const i18n = i18nData || { ko: {}, en: {}, ja: {} };

// 날짜순 정렬 후 5+5 분리
const sortedPosts = [...posts].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
const topPosts = sortedPosts.slice(0, 5);
const bottomPosts = sortedPosts.slice(5, 10);
---

<html lang="ko">
<head>
  <meta charset="utf-8" />
  <title>📟 OTOMAD HUB</title>
  <style>
    body { background-color: #0c0c0c; color: #00ff41; font-family: 'Courier New', monospace; padding: 2rem; margin: 0; }
    
    /* 언어 스위처 - 화면 상단 우측 고정 */
    .lang-switcher { 
      display: flex; gap: 10px; justify-content: flex-end; margin-bottom: 20px;
      border-bottom: 1px solid #333; padding-bottom: 10px;
    }
    .lang-btn { 
      background: #222; border: 1px solid #00ff41; color: #00ff41; 
      cursor: pointer; padding: 5px 12px; font-size: 0.8rem; font-family: inherit;
    }
    .lang-btn.active { background: #00ff41; color: #000; font-weight: bold; }
    .lang-btn:hover { background: #fff; color: #000; }

    header { border-bottom: 2px solid #00ff41; padding-bottom: 1rem; margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: center; }
    h1 { margin: 0; font-size: 1.8rem; text-shadow: 0 0 10px #00ff41; }
    nav a { color: #00ff41; text-decoration: none; margin-left: 15px; font-size: 0.9rem; }
    nav a:hover { background: #00ff41; color: #000; }

    /* 레이아웃 디자인 */
    h2 { border-left: 5px solid #00ff41; padding-left: 10px; margin: 30px 0 20px 0; font-size: 1.2rem; }
    .top-section { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; }
    .big-card { border: 2px solid #00ff41; padding: 20px; background: rgba(0,255,65,0.05); transition: 0.3s; }
    .big-card:hover { transform: translateY(-5px); box-shadow: 0 5px 15px rgba(0,255,65,0.3); }
    
    .bottom-section { margin-top: 30px; border-top: 1px solid #333; }
    .small-list { border-bottom: 1px solid #222; padding: 12px 5px; display: flex; justify-content: space-between; align-items: center; }
    
    .category-tag { background: #00ff41; color: #000; padding: 2px 6px; font-size: 0.7rem; font-weight: bold; margin-bottom: 10px; display: inline-block; }
    .post-title { color: #fff; text-decoration: none; font-size: 1.1rem; font-weight: bold; display: block; margin: 5px 0; }
    .original-title { color: #666; font-size: 0.8rem; display: block; }
    .info { color: #888; font-size: 0.85rem; margin-top: 10px; }
  </style>
</head>
<body>
  <div class="lang-switcher">
    <button class="lang-btn active" onclick="changeLanguage('ko')">한국어</button>
    <button class="lang-btn" onclick="changeLanguage('en')">English</button>
    <button class="lang-btn" onclick="changeLanguage('ja')">日本語</button>
  </div>

  <header>
    <h1 id="site-title">{i18n.ko?.title}</h1>
    <nav>
      <a href="/otomadbloghub/" data-i18n="home">{i18n.ko?.home}</a>
      <a href="/otomadbloghub/admin" data-i18n="admin">{i18n.ko?.admin}</a>
      <a href="https://docs.google.com/forms/..." target="_blank" data-i18n="suggest">{i18n.ko?.suggest}</a>
    </nav>
  </header>

  <main>
    <h2 data-i18n="latest">{i18n.ko?.latest}</h2>
    
    <div class="top-section">
      {topPosts.map(post => (
        <div class="big-card">
          <span class="category-tag">{post.category}</span>
          <a href={post.url} target="_blank" class="post-title" data-titles={JSON.stringify(post.titles)}>
            {post.titles?.ko || post.original_title}
          </a>
          <span class="original-title" data-original={post.original_title}>
            {i18n.ko?.original}: {post.original_title}
          </span>
          <div class="info">Author: {post.author} | {post.platform}</div>
        </div>
      ))}
    </div>

    <div class="bottom-section">
      {bottomPosts.map(post => (
        <div class="small-list">
          <a href={post.url} target="_blank" class="post-title" style="font-size: 0.95rem;" data-titles={JSON.stringify(post.titles)}>
            {post.titles?.ko || post.original_title}
          </a>
          <span style="color: #666; font-size: 0.85rem;">{post.author}</span>
        </div>
      ))}
    </div>
  </main>

  <script is:inline define:vars={{ i18n }}>
    window.changeLanguage = function(lang) {
      // 버튼 상태 변경
      document.querySelectorAll('.lang-btn').forEach(btn => {
        btn.classList.toggle('active', btn.innerText.toLowerCase().includes(lang) || (lang === 'ko' && btn.innerText === '한국어'));
      });

      // 고정 텍스트 변경
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.dataset.i18n;
        if (i18n[lang][key]) el.innerText = i18n[lang][key];
      });
      
      const titleEl = document.getElementById('site-title');
      if (titleEl && i18n[lang].title) titleEl.innerText = i18n[lang].title;

      // 게시글 제목 변경
      document.querySelectorAll('.post-title').forEach(el => {
        const titles = JSON.parse(el.dataset.titles || '{}');
        el.innerText = titles[lang] || titles['ko'] || el.innerText;
      });

      // 원제 라벨 변경
      document.querySelectorAll('.original-title').forEach(el => {
        const originalText = el.dataset.original;
        el.innerText = `${i18n[lang].original}: ${originalText}`;
      });
    }
  </script>
</body>
</html>