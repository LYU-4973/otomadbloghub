---
import postsData from '../data.json';
import i18nData from '../i18n.json';

// 데이터가 없을 경우를 대비한 방어 코드
const posts = postsData || [];
const i18n = i18nData || { ko: {}, en: {}, ja: {} };

// 최신글 5개 + 나머지 5개 분리 (데이터가 있을 때만 정렬)
const sortedPosts = [...posts].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
const topPosts = sortedPosts.slice(0, 5);
const bottomPosts = sortedPosts.slice(5, 10);
---

<html lang="ko">
<head>
  <meta charset="utf-8" />
  <title>📟 OTOMAD HUB</title>
  <style>
    body { background-color: #0c0c0c; color: #00ff41; font-family: 'Courier New', monospace; padding: 2rem; }
    .lang-switcher { display: flex; gap: 10px; margin-bottom: 20px; justify-content: flex-end; }
    .lang-btn { background: none; border: 1px solid #333; color: #888; cursor: pointer; padding: 4px 8px; font-size: 0.8rem; }
    .lang-btn.active { border-color: #00ff41; color: #00ff41; font-weight: bold; }
    
    .top-section { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-bottom: 40px; }
    .big-card { border: 2px solid #00ff41; padding: 20px; background: rgba(0,255,65,0.05); }
    .small-list { border-top: 1px solid #333; padding: 10px 0; display: flex; align-items: center; gap: 15px; }
    .original-title { font-size: 0.8rem; color: #666; margin-top: 4px; display: block; }
    a { color: #fff; text-decoration: none; }
    a:hover { text-decoration: underline; color: #00ff41; }
  </style>
</head>
<body>
  <div class="lang-switcher">
    <button class="lang-btn active" onclick="changeLanguage('ko')">한국어</button>
    <button class="lang-btn" onclick="changeLanguage('en')">English</button>
    <button class="lang-btn" onclick="changeLanguage('ja')">日本語</button>
  </div>

  <header style="border-bottom: 2px solid #00ff41; padding-bottom: 1rem; margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: center;">
    <h1 id="site-title">{i18n.ko?.title || 'OtoMAD HUB'}</h1>
    <nav style="display: flex; gap: 15px;">
      <a href="/otomadbloghub/" data-i18n="home">{i18n.ko?.home}</a>
      <a href="/otomadbloghub/admin" data-i18n="admin">{i18n.ko?.admin}</a>
    </nav>
  </header>

  <main>
    <h2 data-i18n="latest" style="margin-bottom: 1.5rem;">{i18n.ko?.latest}</h2>
    
    <div class="top-section">
      {topPosts.map(post => (
        <div class="big-card">
          <div style="background:#00ff41; color:#000; display:inline-block; padding:2px 6px; font-size:0.7rem; font-weight:bold; margin-bottom:10px;">{post.category}</div>
          <br/>
          <a href={post.url} class="post-title" data-titles={JSON.stringify(post.titles)}>
            {post.titles?.ko || post.title}
          </a>
          <span class="original-title" data-i18n="original">{i18n.ko?.original}: {post.original_title}</span>
          <div style="font-size:0.8rem; color:#888; margin-top:10px;">Author: {post.author}</div>
        </div>
      ))}
    </div>

    <div class="bottom-section">
      {bottomPosts.map(post => (
        <div class="small-list">
          <span style="color:#00ff41; font-size:0.8rem;">[{post.category}]</span>
          <a href={post.url} class="post-title" data-titles={JSON.stringify(post.titles)}>
            {post.titles?.ko || post.title}
          </a>
          <span style="margin-left:auto; font-size:0.8rem; color:#666;">{post.author}</span>
        </div>
      ))}
    </div>
  </main>

  <script is:inline define:vars={{ i18n }}>
    window.changeLanguage = function(lang) {
      // 1. 버튼 활성화 표시
      document.querySelectorAll('.lang-btn').forEach(btn => {
        btn.classList.toggle('active', btn.innerText.toLowerCase().includes(lang) || (lang === 'ko' && btn.innerText === '한국어'));
      });

      // 2. 고정 문구 변경
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.dataset.i18n;
        if (i18n[lang] && i18n[lang][key]) {
          // "원제: 제목" 형태를 유지하기 위한 조건 처리
          if (key === 'original') {
            const originalTitle = el.innerText.split(': ')[1];
            el.innerText = `${i18n[lang][key]}: ${originalTitle}`;
          } else {
            el.innerText = i18n[lang][key];
          }
        }
      });
      
      const titleEl = document.getElementById('site-title');
      if (titleEl && i18n[lang]?.title) titleEl.innerText = i18n[lang].title;

      // 3. 게시글 제목 변경
      document.querySelectorAll('.post-title').forEach(el => {
        const titles = JSON.parse(el.dataset.titles || '{}');
        el.innerText = titles[lang] || titles['ko'] || el.innerText;
      });
    }
  </script>
</body>
</html>