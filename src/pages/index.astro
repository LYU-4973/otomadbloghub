---
import posts from '../data.json';
import i18n from '../i18n.json';

// 최신글 5개 + 나머지 5개 분리
const sortedPosts = posts.sort((a, b) => new Date(b.date) - new Date(a.date));
const topPosts = sortedPosts.slice(0, 5);
const bottomPosts = sortedPosts.slice(5, 10);
---

<html lang="ko">
<head>
  <meta charset="utf-8" />
  <title>📟 OTOMAD HUB</title>
  <style>
    /* 언어 선택 버튼 스타일 */
    .lang-switcher { display: flex; gap: 10px; margin-bottom: 20px; justify-content: flex-end; }
    .lang-btn { 
      background: none; border: 1px solid #333; color: #888; cursor: pointer; padding: 4px 8px; font-size: 0.8rem;
    }
    .lang-btn.active { border-color: #00ff41; color: #00ff41; font-weight: bold; }
    
    /* 5+5 레이아웃 스타일 */
    .top-section { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-bottom: 40px; }
    .big-card { border: 2px solid #00ff41; padding: 20px; background: rgba(0,255,65,0.05); }
    .small-list { border-top: 1px solid #333; padding: 10px 0; display: flex; align-items: center; gap: 15px; }
    
    .original-title { font-size: 0.8rem; color: #666; margin-top: 4px; display: block; }
  </style>
</head>
<body>
  <div class="lang-switcher">
    <button class="lang-btn active" data-lang="ko">한국어</button>
    <button class="lang-btn" data-lang="en">English</button>
    <button class="lang-btn" data-lang="ja">日本語</button>
  </div>

  <header>
    <h1 id="site-title">{i18n.ko.title}</h1>
    <nav>
      <a href="/otomadbloghub/" class="nav-item" data-i18n="home">{i18n.ko.home}</a>
      <a href="/otomadbloghub/admin" class="nav-item" data-i18n="admin">{i18n.ko.admin}</a>
    </nav>
  </header>

  <main>
    <h2 data-i18n="latest">{i18n.ko.latest}</h2>
    
    <div class="top-section">
  {topPosts.map(post => (
    <div class="big-card">
      <div class="category">{post.category}</div>
      <a href={post.url} class="post-title" data-titles={JSON.stringify(post.titles)}>
        {post.titles.ko}
      </a>
      <span class="original-title" data-i18n="original">원제: {post.original_title}</span>
      <div class="info">Author: {post.author}</div>
    </div>
  ))}
</div>

    <div class="bottom-section">
      {bottomPosts.map(post => (
        <div class="small-list">
          <span>[{post.category}]</span>
          <a href={post.url}>{post.title}</a>
          <span style="margin-left:auto">{post.author}</span>
        </div>
      ))}
    </div>
  </main>

  <script is:inline>
  // 버튼 누를 때 제목도 같이 바뀌게 수정
  function changeLanguage(lang) {
    // ... 기존 i18n 문구 변경 코드 ...

    // 제목들 변경
    document.querySelectorAll('.post-title').forEach(el => {
      const titles = JSON.parse(el.dataset.titles);
      el.innerText = titles[lang] || titles['ko'];
    });
  }
</script>
</body>
</html>