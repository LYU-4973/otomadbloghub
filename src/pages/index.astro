---
import posts from '../data.json';
---

<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <title>📟 OTOMAD HUB</title>
    <style>
      /* 전체 배경과 폰트 설정 */
      body { 
        background-color: #0c0c0c; 
        color: #00ff41; 
        font-family: 'Courier New', Courier, monospace; 
        padding: 2rem; 
        line-height: 1.6;
        margin: 0;
      }

      /* 헤더 영역: 로고와 메뉴를 양 끝으로 정렬 */
      header {
        border-bottom: 2px solid #00ff41;
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      h1 { 
        margin: 0; 
        font-size: 1.8rem; 
        text-shadow: 0 0 10px #00ff41; 
      }

      /* 네비게이션 링크 공통 스타일 */
      nav {
        display: flex;
        gap: 15px;
      }

      .nav-item {
        text-decoration: none;
        font-size: 0.9rem;
        padding: 4px 8px;
        transition: all 0.2s;
        border: 1px solid transparent;
      }

      .nav-item:hover {
        background: #00ff41;
        color: #000;
        border: 1px solid #00ff41;
      }

      /* 각 링크 색상 별도 지정 */
      .home, .admin { color: #00ff41; }
      .suggest { color: #ffff00; font-weight: bold; }

      /* 상태바 */
      .status {
        font-size: 0.9rem;
        margin-bottom: 1.5rem;
        opacity: 0.8;
      }

      /* 리스트 스타일 */
      ul { list-style: none; padding: 0; }
      li { 
        border: 1px solid #333; 
        margin-bottom: 1rem; 
        padding: 1.2rem; 
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
      }

      /* 리스트 호버 효과: 터미널 느낌 강조 */
      li:hover { 
        border-color: #00ff41; 
        background: rgba(0, 255, 65, 0.05); 
        transform: translateX(10px);
        box-shadow: -5px 0 0 #00ff41;
      }

      .category {
        background: #00ff41;
        color: #000;
        padding: 2px 8px;
        font-size: 0.75rem;
        font-weight: bold;
        margin-right: 12px;
        display: inline-block;
        margin-bottom: 8px;
      }

      .post-link {
        color: #fff;
        text-decoration: none;
        font-size: 1.15rem;
        font-weight: bold;
      }

      .post-link:hover {
        color: #00ff41;
        text-decoration: underline;
      }

      .info {
        margin-top: 12px;
        font-size: 0.85rem;
        color: #888;
      }

      .info span { color: #bbb; }
    </style>
  </head>
  <body>
    <header>
      <h1>📟 OTOMAD HUB</h1>
      <nav>
        <a href="/otomadbloghub/" class="nav-item home">[HOME]</a> 
        <a href="/otomadbloghub/admin" class="nav-item admin">[ADMIN]</a>
        <a href="https://docs.google.com/forms/d/e/1FAIpQLSeUuSy4tBnys3QcGEj42VVRH06_UPTICWuH3rIXUkTgagnT9g/viewform?usp=dialog" target="_blank" class="nav-item suggest">[+ SUGGEST]</a>
      </nav>
    </header>

    <main>
      <p class="status">>> CONNECTION ESTABLISHED. TOTAL TERMINALS: {posts.length}</p>
      <ul>
        {posts.map((post) => (
          <li>
            <div class="category">{post.category}</div>
            <a href={post.url} target="_blank" class="post-link">{post.title}</a>
            <div class="info">
              Author: <span>{post.author}</span> | Platform: <span>{post.platform}</span>
            </div>
          </li>
        ))}
      </ul>
    </main>
  </body>
</html>